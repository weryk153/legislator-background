---
import Base from "../../layouts/Base.astro";
import Sources from "../../components/Sources.astro";
import { loadOfficials } from "../../lib/data";
import { egoSubgraph, RELATION_LABEL, FAMILY_RELATIONS } from "../../lib/graph";
import { loadGraph } from "../../lib/loadGraph";

export async function getStaticPaths() {
  const officials = await loadOfficials();
  const graph = loadGraph();
  return officials.map((o) => ({
    params: { id: o.slug },
    props: { official: o, ego: egoSubgraph(graph, `official:${o.id}`, 1) },
  }));
}

const { official: o, ego } = Astro.props;
// 本人的直接人物關係（取與本人相連的邊，找出對方節點），以文字清單呈現。
const centerKey = `official:${o.id}`;
const egoByKey = new Map(ego.nodes.map((n) => [n.key, n]));
const relations = ego.edges
  .filter((e) => e.source === centerKey || e.target === centerKey)
  .map((e) => {
    const otherKey = e.source === centerKey ? e.target : e.source;
    return { other: egoByKey.get(otherKey)!, type: e.type, note: e.note, sourceUrl: e.sourceUrl };
  });
const statusLabel = {
  investigating: "偵查中", indicted: "已起訴", first_instance: "一審",
  settled: "已和解", cleared: "查無不法", other: "未分類",
};

// Conservatively infer a legal stage from the report text, ONLY on unambiguous wording, so
// the badge reflects what the cited reports say rather than asserting a verdict. Anything
// unclear stays "未分類". Real data (a non-'other' status) is respected as-is. The section
// disclaimer makes clear this is per-report and 以官方資料為準.
function inferStatus(c: { status: string; summary: string; title: string }): string {
  if (c.status && c.status !== "other") return c.status;
  const s = `${c.title} ${c.summary}`;
  if (/不起訴|無罪|查無不法|簽結|不予起訴/.test(s)) return "cleared";
  if (/和解|撤回(告訴|起訴)|撤告/.test(s)) return "settled";
  if (/起訴|提起公訴|聲請簡易判決|遭訴/.test(s)) return "indicted";
  if (/偵查|檢調|約談|搜索|聲押|分他字|列為被告/.test(s)) return "investigating";
  if (/一審|二審|更一審|地方法院.{0,6}判|高等法院.{0,6}判|判處|判刑|有期徒刑/.test(s)) return "first_instance";
  return "other";
}
const fmt = (n: number) => new Intl.NumberFormat("zh-Hant").format(n);
const assetCategoryName: Record<string, string> = {
  land: "土地", building: "建物", cash: "現金", deposit: "存款",
  securities: "有價證券", investment: "事業投資", claim: "債權", debt: "債務", other: "其他",
};
const officeName: Record<string, string> = { legislator: "立委", mayor_magistrate: "縣市首長", councilor: "議員" };
const desc = `${o.name}（${o.party}・${officeName[o.officeType]}・${o.district}）的經歷、財產申報與相關爭議報導整理，每筆皆附公開資料出處。`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: o.name,
  jobTitle: officeName[o.officeType],
  affiliation: { "@type": "Organization", name: o.party },
  url: Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined,
};
---
<Base title={`${o.name}｜政治人物背景`} description={desc}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <a href="/" class="back">← 返回總覽</a>

  <header class="head">
    <span class="pill">{officeName[o.officeType]}</span>
    {o.departedReason && <span class="pill departed">已解職</span>}
    <h1>{o.name}</h1>
    <p class="lede">{o.party}・{o.district}・第{o.term}屆{o.bio ? `　${o.bio}` : ""}</p>
    {o.departedReason && <p class="departed-note">本人已非現任：{o.departedReason}。以下為其任內（第{o.term}屆當選時）之公開資料。</p>}
  </header>

  <section class="sec">
    <h2>經歷</h2>
    {o.careers.length === 0 && <p class="dim none">尚無資料</p>}
    {o.careers.map((c) => (
      <div class="item">
        <div><strong class="num">{c.startDate}–{c.endDate ?? "現任"}</strong>　{c.organization}　{c.title}</div>
        <Sources sources={[c.source]} />
      </div>
    ))}
  </section>

  <section class="sec">
    <h2>司法判決</h2>
    <p class="note">判決結果不代表最終定罪；未定讞案件當事人依法受無罪推定保障。</p>
    {o.judgments.length === 0 && <p class="dim none">尚無資料</p>}
    {o.judgments.map((j) => (
      <article class="card entry">
        <div class="entry-head">{j.caseReason}　<span class="accent">{j.outcome}</span></div>
        <div class="entry-meta">{j.court}　{j.caseNumber}　<span class="num">{j.judgmentDate}</span>　<span class="pill">{j.isFinal ? "已定讞" : "尚未定讞"}</span></div>
        <Sources sources={[j.source]} />
      </article>
    ))}
  </section>

  <section class="sec">
    <h2>相關爭議報導</h2>
    {o.controversies.length > 0 && (
      <p class="note">
        以下為維基百科與所附媒體報導之<strong>整理</strong>，屬外部報導與指控，
        <strong>非本站認定之事實，亦未經本站逐筆查核</strong>。法律狀態以司法、官方資料為準；
        未定讞前當事人依法受無罪推定保障。狀態標示係依報導文字研判，僅供參考。請逕點各筆出處核對。
        部分內容改寫自維基百科，依 <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener">CC BY-SA 4.0</a> 授權。
      </p>
    )}
    {o.controversies.length === 0 && <p class="dim none">尚無資料</p>}
    {o.controversies.map((c) => (
      <article class="card entry">
        <div class="entry-head">{c.title}　<span class="pill">{statusLabel[inferStatus(c)]}</span></div>
        <p class="entry-body">{c.summary}</p>
        <div class="entry-meta">整理日期：<span class="num">{c.reportDate}</span></div>
        <Sources sources={c.sources} />
      </article>
    ))}
  </section>

  <section class="sec">
    <h2>財產申報</h2>
    {o.assets.length > 0 && <p class="note">金額由程式自動解析監察院公報 PDF，可能有解析誤差；土地/建物因多數逾五年免申報價額，僅列筆數。請點出處核對。</p>}
    {o.assets.length === 0 && <p class="dim none">尚無資料</p>}
    {o.assets.map((a) => (
      <div class="item">
        <div><strong class="num">{a.year}</strong></div>
        {a.items.length === 0 && <div class="dim" style="font-size:13px">金額待人工從公報補錄</div>}
        {a.items.map((it) => (
          <div style="font-size:13px;display:flex;gap:10px">
            <span style="color:var(--muted);min-width:5em">{assetCategoryName[it.category] ?? it.category}</span>
            {it.label === "count"
              ? <span class="num">{it.amount} 筆<span style="color:var(--faint)">（取得價額見公報）</span></span>
              : <span class="num">NT$ {fmt(it.amount)}</span>}
          </div>
        ))}
        <Sources sources={[a.source]} />
      </div>
    ))}
  </section>

  {relations.length > 0 && (
    <section class="sec">
      <h2>人物關係</h2>
      <p class="note">關係資料整理自司法判決、媒體報導與公開資料，每條皆附出處，僅呈現已查證者。連結者為公職人員（可點入檔案），其餘為其他公眾人物。</p>
      {relations.map((r) => (
        <div class="item rel">
          <span class={`pill rel-kind ${FAMILY_RELATIONS.has(r.type) ? "fam" : "pol"}`}>{RELATION_LABEL[r.type]}</span>
          {r.other.slug
            ? <a class="rel-name" href={`/officials/${r.other.slug}`}>{r.other.name}</a>
            : <span class="rel-name plain">{r.other.name}<span class="rel-ext">（非公職）</span></span>}
          {r.note && <span class="rel-note">{r.note}</span>}
          {r.sourceUrl && <a class="rel-src" href={r.sourceUrl} target="_blank" rel="noopener">出處 ↗</a>}
        </div>
      ))}
    </section>
  )}

  <style>
    .back { font-size: 0.8125rem; color: var(--muted); }
    .back:hover { color: var(--accent); }
    .head { margin: 14px 0 36px; }
    .head h1 { font-size: var(--t-xl); margin: 10px 0 6px; }
    .head .lede { margin: 0; }
    .pill.departed { margin-left: 6px; color: #b3261e; border-color: #b3261e; }
    .departed-note { margin: 12px 0 0; font-size: 0.8125rem; color: #b3261e; max-width: 64ch; line-height: 1.6; }
    .sec { margin-bottom: 40px; }
    .sec h2 {
      font-size: 1.25rem; margin: 0 0 14px;
      padding-bottom: 8px; border-bottom: 1px solid var(--line-strong);
    }
    .note { font-size: var(--t-sm); color: var(--muted); margin: -4px 0 16px; }
    .none { padding: 4px 0; }
    .item { margin: 12px 0; }
    .entry { margin: 12px 0; }
    .entry-head { font-weight: 700; font-size: 1.0625rem; }
    .entry-body { margin: 6px 0; font-size: 0.9375rem; }
    .entry-meta { font-size: var(--t-sm); color: var(--muted); margin-top: 4px; }
    .asset { font-weight: 700; }
    .rel { display: flex; flex-wrap: wrap; align-items: baseline; gap: 7px 11px; padding: 11px 0; border-bottom: 1px solid var(--line); }
    .rel-kind { flex: none; }
    .rel-kind.pol { border-style: dashed; }
    .rel-name { font-family: var(--serif); font-weight: 700; font-size: 1.0625rem; }
    a.rel-name:hover { color: var(--accent); }
    .rel-name.plain { color: var(--muted); }
    .rel-ext { font-family: var(--sans); font-weight: 400; font-size: var(--t-sm); color: var(--faint); }
    .rel-note { color: var(--muted); font-size: 0.9375rem; }
    .rel-src { margin-left: auto; font-size: var(--t-sm); color: var(--muted); text-decoration: underline; text-underline-offset: 2px; }
    .rel-src:hover { color: var(--accent); }
  </style>
</Base>
