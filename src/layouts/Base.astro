---
import { readFileSync } from "node:fs";
import { join } from "node:path";
import "../styles/tokens.css";
const { title = "公職人員背景資料庫" } = Astro.props;
let dataDate = "";
try {
  dataDate = JSON.parse(readFileSync(join(process.cwd(), "src", "data", "meta.json"), "utf8")).generatedAt ?? "";
} catch { /* meta.json optional */ }
---
<!DOCTYPE html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="以可查證、附出處的方式，公開現任公職人員的經歷、司法判決、爭議事件與財產申報。" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@600;700;900&family=Public+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      const t = localStorage.getItem("theme");
      if (t) document.documentElement.dataset.theme = t;
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">跳至主要內容</a>

    <header class="site-head">
      <div class="wrap head-inner">
        <a href="/" class="brand" aria-label="回首頁">
          <span class="kicker">Public Office Watch</span>
          <span class="brand-name">公職人員背景</span>
        </a>
        <nav class="nav" aria-label="主選單">
          <a href="/">總覽</a>
          <a href="/about">關於</a>
          <button id="theme-toggle" type="button" class="toggle" aria-label="切換深色或淺色模式">
            <svg class="ic-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
            </svg>
            <svg class="ic-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main id="main" class="wrap main">
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <p>本站僅呈現合法公開資料並標註出處，不對個人作價值判斷。司法判決與爭議資訊不代表最終定罪，當事人受無罪推定保障。</p>
        <p>本站非官方網站；資料來源為監察院公報、中選會、立法院、司法院與維基百科等公開資料。部分內容依 CC BY-SA 4.0 授權。</p>
        <p class="foot-meta">{dataDate && <>資料更新：{dataDate}　·　</>}資料如有誤或需更正，歡迎至 <a href="https://github.com/weryk153/legislator-background/issues" target="_blank" rel="noopener">GitHub 回報</a>。　·　<a href="/about#correction">更正與權利</a>　·　<a href="/about">資料來源與方法論</a></p>
      </div>
    </footer>

    <script is:inline>
      document.getElementById("theme-toggle").addEventListener("click", () => {
        const cur = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = cur;
        localStorage.setItem("theme", cur);
      });
    </script>

    <style>
      .site-head { border-bottom: 2px solid var(--line-strong); }
      .head-inner {
        display: flex; justify-content: space-between; align-items: flex-end;
        padding-top: 22px; padding-bottom: 16px;
      }
      .brand { display: flex; flex-direction: column; gap: 3px; }
      .brand-name { font-family: var(--serif); font-size: 1.375rem; font-weight: 900; }
      .brand:hover .brand-name { color: var(--accent); }
      .nav { display: flex; gap: 20px; align-items: center; font-size: 0.875rem; }
      .nav a { color: var(--muted); padding-bottom: 2px; }
      .nav a:hover { color: var(--fg); }
      .toggle {
        display: inline-flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; padding: 0;
        background: none; border: 1px solid var(--line-strong); border-radius: 8px;
        color: var(--fg); cursor: pointer; transition: border-color var(--ease), color var(--ease);
      }
      .toggle:hover { border-color: var(--accent); color: var(--accent); }
      .ic-moon { display: none; }
      :root[data-theme="dark"] .ic-sun { display: none; }
      :root[data-theme="dark"] .ic-moon { display: inline; }
      .main { padding-top: 32px; padding-bottom: 72px; min-height: 60vh; }
      .site-foot {
        border-top: 1px solid var(--line);
        padding: 28px 0 40px;
        font-size: var(--t-sm); color: var(--muted); line-height: 1.7;
      }
      .site-foot p { margin: 0 0 6px; max-width: 70ch; }
      .foot-meta { color: var(--faint); }
      .foot-meta a { text-decoration: underline; text-underline-offset: 2px; }
      .foot-meta a:hover { color: var(--accent); }
    </style>
  </body>
</html>
